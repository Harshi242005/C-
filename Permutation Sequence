class Solution {
public:
    string getPermutation(int n, int k) {
        int fact = 1;
        vector<int> numbers;
        
        // Calculate (n-1)! and fill numbers list {1, 2, ..., n}
        for (int i = 1; i < n; i++) {
            fact *= i;
            numbers.push_back(i);
        }
        numbers.push_back(n);
        
        string result = "";
        k = k - 1; // Use 0-based indexing for math logic
        
        while (true) {
            // Find the index of the digit to use
            int index = k / fact;
            result += to_string(numbers[index]);
            
            // Remove used digit from the pool
            numbers.erase(numbers.begin() + index);
            
            if (numbers.empty()) break;
            
            // Update k and fact for the next position
            k = k % fact;
            fact = fact / numbers.size();
        }
        
        return result;
    }
};
