class LRUCache : public Cache {
public:
    LRUCache(int capacity) {
        cp = capacity;
        head = NULL;
        tail = NULL;
    }

    void set(int key, int value) override {
        if (mp.find(key) != mp.end()) {
            // Cache Hit: Update value and move to head
            Node* node = mp[key];
            node->value = value;
            moveToHead(node);
        } else {
            // Cache Miss: Create new node
            Node* newNode = new Node(NULL, head, key, value);
            if (head) head->prev = newNode;
            head = newNode;
            if (!tail) tail = newNode;
            mp[key] = newNode;

            if (mp.size() > cp) {
                // Remove LRU (tail)
                mp.erase(tail->key);
                Node* temp = tail;
                tail = tail->prev;
                if (tail) tail->next = NULL;
                delete temp;
            }
        }
    }

    int get(int key) override {
        if (mp.find(key) == mp.end()) return -1;
        
        // Cache Hit: Move to head and return value
        Node* node = mp[key];
        moveToHead(node);
        return node->value;
    }

private:
    void moveToHead(Node* node) {
        if (node == head) return;
        
        if (node == tail) {
            tail = tail->prev;
            tail->next = NULL;
        } else {
            node->prev->next = node->next;
            node->next->prev = node->prev;
        }
        
        node->next = head;
        node->prev = NULL;
        head->prev = node;
        head = node;
    }
};
