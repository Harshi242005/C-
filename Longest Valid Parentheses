class Solution {
public:
    int longestValidParentheses(string s) {
        stack<int> st;
        // Push -1 as a base index for calculation
        st.push(-1);
        int maxLen = 0;

        for (int i = 0; i < s.length(); i++) {
            if (s[i] == '(') {
                // Store the index of the opening bracket
                st.push(i);
            } else {
                // It's a closing bracket: pop the last opening bracket
                st.pop();
                
                if (st.empty()) {
                    // If empty, this ')' is an invalid "floor" for future substrings
                    st.push(i);
                } else {
                    // Current valid length is (current index - index of the last unmatched element)
                    maxLen = max(maxLen, i - st.top());
                }
            }
        }
        
        return maxLen;
    }
};
