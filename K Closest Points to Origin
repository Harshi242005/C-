#include <vector>
#include <queue>

using namespace std;

class Solution {
public:
    vector<vector<int>> kClosest(vector<vector<int>>& points, int k) {
        // Max-heap to store the k closest points
        // We store pairs of {distance_squared, point_index}
        priority_queue<pair<int, int>> maxHeap;

        for (int i = 0; i < points.size(); ++i) {
            // Euclidean distance squared: x^2 + y^2 (no need for sqrt)
            int dist = points[i][0] * points[i][0] + points[i][1] * points[i][1];
            
            maxHeap.push({dist, i});
            
            // If heap size exceeds k, remove the farthest point
            if (maxHeap.size() > k) {
                maxHeap.pop();
            }
        }

        // Extract the k points from the heap into the result vector
        vector<vector<int>> result;
        while (!maxHeap.empty()) {
            result.push_back(points[maxHeap.top().second]);
            maxHeap.pop();
        }
        
        return result;
    }
};
