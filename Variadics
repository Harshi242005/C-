#include <iostream>
using namespace std;

/// 1. Base case: This matches when the template is called with NO arguments
template <bool... digits>
struct BinaryValue {
    static const int value = 0;
};

// 2. Recursive case: Peels off the 'first' bit and processes the 'rest'
template <bool first, bool... rest>
struct BinaryValue<first, rest...> {
    // We shift the value of the 'rest' to the left (multiply by 2) 
    // and add the current 'first' bit.
    static const int value = (BinaryValue<rest...>::value << 1) + first;
};

// 3. The function required by the challenge
template <bool... digits>
int reversed_binary_value() {
    return BinaryValue<digits...>::value;
}


template <int n, bool...digits>
struct CheckValues {
  	static void check(int x, int y)
  	{
    	CheckValues<n-1, 0, digits...>::check(x, y);
    	CheckValues<n-1, 1, digits...>::check(x, y);
  	}
};

template <bool...digits>
struct CheckValues<0, digits...> {
  	static void check(int x, int y)
  	{
    	int z = reversed_binary_value<digits...>();
    	std::cout << (z+64*y==x);
  	}
};

int main()
{
  	int t; std::cin >> t;

  	for (int i=0; i!=t; ++i) {
		int x, y;
    	cin >> x >> y;
    	CheckValues<6>::check(x, y);
    	cout << "\n";
  	}
}
