class Solution {
    unordered_map<string, vector<string>> adj;
    unordered_map<string, int> distance;
    vector<vector<string>> results;

public:
    vector<vector<string>> findLadders(string beginWord, string endWord, vector<string>& wordList) {
        unordered_set<string> dict(wordList.begin(), wordList.end());
        if (dict.find(endWord) == dict.end()) return {};

        // 1. BFS to find shortest distances and build adjacency graph
        queue<string> q;
        q.push(beginWord);
        distance[beginWord] = 0;

        while (!q.empty()) {
            string word = q.front();
            q.pop();

            string nextWord = word;
            for (int i = 0; i < nextWord.size(); i++) {
                char originalChar = nextWord[i];
                for (char c = 'a'; c <= 'z'; c++) {
                    nextWord[i] = c;
                    if (dict.count(nextWord)) {
                        if (distance.find(nextWord) == distance.end()) {
                            distance[nextWord] = distance[word] + 1;
                            q.push(nextWord);
                            adj[nextWord].push_back(word);
                        } else if (distance[nextWord] == distance[word] + 1) {
                            adj[nextWord].push_back(word);
                        }
                    }
                }
                nextWord[i] = originalChar;
            }
        }

        // 2. DFS to reconstruct paths from endWord to beginWord
        if (distance.count(endWord)) {
            vector<string> path = {endWord};
            backtrack(endWord, beginWord, path);
        }

        return results;
    }

private:
    void backtrack(string currentWord, string& target, vector<string>& path) {
        if (currentWord == target) {
            vector<string> res = path;
            reverse(res.begin(), res.end());
            results.push_back(res);
            return;
        }

        for (string& prev : adj[currentWord]) {
            path.push_back(prev);
            backtrack(prev, target, path);
            path.pop_back();
        }
    }
};
