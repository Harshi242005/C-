#include <stdio.h>
#include <cstdlib> // Required for abs()

void update(int *a, int *b) {
    // 1. Store the original value of *a
    int original_a = *a;
    int original_b = *b;
    
    // 2. Update *a with the sum
    *a = original_a + original_b;
    
    // 3. Update *b with the absolute difference
    // abs() ensures the result is always positive
    *b = abs(original_a - original_b);
}

int main() {
    int a, b;
    int *pa = &a, *pb = &b;
    
    scanf("%d %d", &a, &b);
    update(pa, pb);
    printf("%d\n%d", a, b);

    return 0;
}
