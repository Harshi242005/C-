#include <iostream>
#include <vector>

using namespace std;

int main() {
    int n, q;
    // Read the number of arrays (n) and the number of queries (q)
    if (!(cin >> n >> q)) return 0;

    // Create a vector of vectors to store the variable-sized arrays
    vector<vector<int>> a(n);

    for (int i = 0; i < n; i++) {
        int k;
        cin >> k; // Read the size of the current array
        a[i].resize(k);
        for (int j = 0; j < k; j++) {
            cin >> a[i][j]; // Read each element of the inner array
        }
    }

    // Process each query
    for (int k = 0; k < q; k++) {
        int i, j;
        cin >> i >> j;
        // Output the element at array index i, element index j
        cout << a[i][j] << endl;
    }

    return 0;
}
