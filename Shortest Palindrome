class Solution {
public:
    string shortestPalindrome(string s) {
        if (s.empty()) return s;

        // 1. Create a combined string: original + separator + reversed original
        // The '#' separator ensures the prefix match stays within the bounds of s
        string rev_s = s;
        reverse(rev_s.begin(), rev_s.end());
        string combined = s + "#" + rev_s;

        // 2. Build the KMP LPS (Longest Prefix Suffix) array
        int n = combined.length();
        vector<int> lps(n, 0);
        
        for (int i = 1; i < n; i++) {
            int j = lps[i - 1];
            while (j > 0 && combined[i] != combined[j]) {
                j = lps[j - 1];
            }
            if (combined[i] == combined[j]) {
                j++;
            }
            lps[i] = j;
        }

        // 3. The last value in the LPS array is the length of the longest palindromic prefix
        int longest_pal_len = lps.back();

        // 4. Take the part of the string that is NOT part of the palindrome, 
        // reverse it, and add it to the front.
        string suffix_to_reverse = s.substr(longest_pal_len);
        reverse(suffix_to_reverse.begin(), suffix_to_reverse.end());

        return suffix_to_reverse + s;
    }
};
