class Solution {
public:
    vector<string> fullJustify(vector<string>& words, int maxWidth) {
        vector<string> result;
        int i = 0;
        
        while (i < words.size()) {
            int j = i + 1;
            int lineLength = words[i].length();
            
            // Step 1: Figure out how many words fit in this line
            while (j < words.size() && lineLength + 1 + words[j].length() <= maxWidth) {
                lineLength += 1 + words[j].length();
                j++;
            }
            
            string line = "";
            int numWords = j - i;
            int numSpaces = maxWidth - (lineLength - (numWords - 1));
            
            // Step 2: Handle Case: Last line or Only one word in line (Left Justified)
            if (j == words.size() || numWords == 1) {
                for (int k = i; k < j; k++) {
                    line += words[k];
                    if (line.length() < maxWidth) line += " ";
                }
                while (line.length() < maxWidth) line += " ";
            } 
            // Step 3: Handle Case: Normal line (Fully Justified)
            else {
                int spacesBetween = numSpaces / (numWords - 1);
                int extraSpaces = numSpaces % (numWords - 1);
                
                for (int k = i; k < j; k++) {
                    line += words[k];
                    if (k < j - 1) {
                        int spacesToApply = spacesBetween + (extraSpaces-- > 0 ? 1 : 0);
                        line.append(spacesToApply, ' ');
                    }
                }
            }
            
            result.push_back(line);
            i = j; // Move to the next set of words
        }
        
        return result;
    }
};
