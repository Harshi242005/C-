class Solution {
public:
    vector<int> maxSlidingWindow(vector<int>& nums, int k) {
        deque<int> dq; // Stores indices
        vector<int> result;
        
        for (int i = 0; i < nums.size(); i++) {
            // 1. Remove indices of elements smaller than current (from back)
            while (!dq.empty() && nums[dq.back()] < nums[i]) {
                dq.pop_back();
            }
            
            // 2. Add current index
            dq.push_back(i);
            
            // 3. Remove index that is out of the current window (from front)
            if (dq.front() == i - k) {
                dq.pop_front();
            }
            
            // 4. If window has reached size k, the front is our current max
            if (i >= k - 1) {
                result.push_back(nums[dq.front()]);
            }
        }
        
        return result;
    }
};
